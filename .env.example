# WQ Brain credentials — copy this to .env and fill in your values
# .env is gitignored and will never be committed.
#
# If these env vars are set, they take priority over credentials.json.
# If not set, the scripts fall back to credentials.json as before.

WQ_EMAIL=your@email.com
WQ_PASSWORD=yourpassword

LINE_CHANNEL_TOKEN=your_line_channel_access_token
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
